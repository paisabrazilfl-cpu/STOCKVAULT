# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/db
# 32-byte hex key used for AES-256-GCM encryption of stored secrets
ENCRYPTION_SECRET=

# ── Alpaca (server-wide / "operator" account) ────────────────────────────────
# When these are set, the broker uses THIS account for every request and the
# Settings UI shows Alpaca as managed/read-only. Leave them unset to let each
# tenant configure their own keys in Settings instead.
#
# Canonical names (preferred); ALPACA_API_KEY_ID / ALPACA_API_SECRET_KEY also work.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# "true" (default) → paper-api.alpaca.markets, "false" → live api.alpaca.markets
ALPACA_PAPER=true
