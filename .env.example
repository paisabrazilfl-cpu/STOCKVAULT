# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/db
# 32-byte hex key used for AES-256-GCM encryption of stored secrets
ENCRYPTION_SECRET=

# ── Alpaca (server-wide / "operator" account) ────────────────────────────────
# When these are set, the broker uses THIS account for every request and the
# Settings UI shows Alpaca as managed/read-only. Leave them unset to let each
# tenant configure their own keys in Settings instead.
#
# Canonical names (preferred); ALPACA_API_KEY_ID / ALPACA_API_SECRET_KEY also work.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# "true" (default) → paper-api.alpaca.markets, "false" → live api.alpaca.markets
ALPACA_PAPER=true

# ── Alpaca Broker API (per-user brokerage accounts) ──────────────────────────
# OPTIONAL: leave unset to let users paste their own Broker keys in Settings.
# When set, these take precedence and the Settings inputs become read-only.
# Get keys from the Broker dashboard: https://broker-app.alpaca.markets/
ALPACA_BROKER_API_KEY=
ALPACA_BROKER_API_SECRET=
# "true" (default) → broker-api.sandbox.alpaca.markets, "false" → live broker-api.alpaca.markets
ALPACA_BROKER_SANDBOX=true

# ── AI engine (OpenAI-compatible; default: NVIDIA NIM) ───────────────────────
# Operator-wide key. Leave unset to let each tenant paste their own key in
# Settings (stored AES-256-GCM encrypted). NEVER hardcode keys in source.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=deepseek-ai/deepseek-v4-pro
# Reasoning mode for DeepSeek-on-NIM (chat_template_kwargs.thinking). Default off.
AI_THINKING=false
